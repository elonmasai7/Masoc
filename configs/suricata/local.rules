alert icmp any any -> $HOME_NET any (msg:"ICMP activity to HOME_NET"; sid:1000001; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 3389 (msg:"External RDP attempt"; sid:1000002; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 445 (msg:"External SMB attempt"; sid:1000003; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"External SSH attempt"; sid:1000004; rev:1;)
