TZ=Africa/Nairobi
CLINIC_NAME=MedShieldClinic

# Network segmentation (align with pfSense/OPNsense VLAN plan)
STAFF_NET=10.10.10.0/24
SERVER_NET=10.10.20.0/24
MEDICAL_NET=10.10.30.0/24
GUEST_NET=10.10.40.0/24
MGMT_NET=10.10.50.0/24

# Wazuh
WAZUH_MANAGER_PORT=1514
WAZUH_API_PORT=55000
WAZUH_DASHBOARD_PORT=5601
INDEXER_PORT=9200
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=change_this_wazuh_password

# WireGuard
WG_HOST=vpn.medshield.local
WG_PORT=51820
WG_PEERS=10
WG_ALLOWEDIPS=10.10.10.0/24,10.10.20.0/24
WG_DNS=1.1.1.1
WG_SUBNET=10.13.13.0/24

# OpenVAS
OPENVAS_WEB_PORT=8080
GVM_ADMIN_USER=admin
GVM_ADMIN_PASSWORD=change_this_gvm_password

# Restic backup
RESTIC_REPOSITORY=s3:https://object-storage.example.com/medshield-backup
RESTIC_PASSWORD=change_this_restic_password
AWS_ACCESS_KEY_ID=change_this_key
AWS_SECRET_ACCESS_KEY=change_this_secret
BACKUP_RETENTION_DAILY=14
BACKUP_RETENTION_WEEKLY=8
BACKUP_RETENTION_MONTHLY=12

# MASOC stream + ML + SOAR controls
FAILED_LOGIN_WINDOW_SEC=300
FAILED_LOGIN_THRESHOLD=6
ML_MIN_TRAIN_SAMPLES=50
ML_HISTORY_SIZE=500
RISK_DEDUP_SECONDS=300

# MASOC connector endpoints/tokens (stubs)
ENTRA_EVENTS_URL=https://graph.microsoft.com/v1.0/auditLogs/signIns
ENTRA_API_TOKEN=replace_me
OKTA_EVENTS_URL=https://your-org.okta.com/api/v1/logs
OKTA_API_TOKEN=replace_me
CROWDSTRIKE_DETECTIONS_URL=https://api.crowdstrike.com/detects/queries/detects/v1
CROWDSTRIKE_API_TOKEN=replace_me
SENTINELONE_ALERTS_URL=https://your-console.sentinelone.net/web/api/v2.1/threats
SENTINELONE_API_TOKEN=replace_me
PROOFPOINT_EVENTS_URL=https://api.proofpoint.com/v2/siem/all
PROOFPOINT_API_TOKEN=replace_me
MIMECAST_EVENTS_URL=https://api.services.mimecast.com/api/audit/get-siem-logs
MIMECAST_API_TOKEN=replace_me
TAXII_COLLECTION_URL=https://taxii.example.org/collections/collection-id/objects
TAXII_API_TOKEN=replace_me
